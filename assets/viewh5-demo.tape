Output assets/viewh5-demo.gif

Require uv

Set Shell "bash"
Set FontSize 22
Set Width 1800
Set Height 1000
Set Padding 20
Set Framerate 30
Set TypingSpeed 25ms
Set WindowBar Colorful

Type "uv run --no-sync viewh5 data/waveforms.h5"
Enter
Sleep 3s

Down
Sleep 700ms
Down
Sleep 700ms
Down
Sleep 700ms

Tab
Sleep 700ms
Ctrl+d
Sleep 900ms
Ctrl+u
Sleep 900ms
Type "h"
Sleep 700ms
Down
Sleep 500ms
Down
Sleep 500ms

Type "q"
Sleep 500ms
